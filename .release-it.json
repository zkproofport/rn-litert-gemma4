{
  "git": {
    "commitMessage": "chore: release ${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": false
  },
  "github": {
    "release": true,
    "assets": ["LiteRTLM-ios-frameworks.zip"]
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": "npm run build",
    "after:bump": "scripts/build-ios-engine.sh"
  }
}
