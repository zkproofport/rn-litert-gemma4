# Prevent npm from auto-installing peer dependencies at the root level.
# This library's peerDependencies (react, react-native, react-native-nitro-modules)
# should only be provided by the consuming app (or the example/ app during development).
# Without this, npm resolves potentially different versions into root node_modules,
# causing expo-doctor "duplicate native module" warnings.
legacy-peer-deps=true
